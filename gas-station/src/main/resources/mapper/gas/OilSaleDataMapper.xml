<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.gas.module.price.mapper.OilSaleDataMapper">

    <resultMap id="OilSaleData" type="com.ruoyi.gas.module.price.domain.OilSaleData">
        <result property="id" column="id"/>
        <result property="gasStationId" column="gas_station_id"/>
        <result property="oilType" column="oil_type"
                typeHandler="com.ruoyi.gas.module.price.mapper.handler.OilTypeHandler"/>
        <result property="LNumber" column="l_number"/>
        <result property="KgNumber" column="kg_number"/>
        <result property="price" column="price"/>
        <result property="date" column="date"
                typeHandler="com.ruoyi.gas.module.price.mapper.handler.DateTimeHandler"/>
        <result property="batch" column="batch"/>
    </resultMap>

    <parameterMap id="OilSaleData" type="com.ruoyi.gas.module.price.domain.OilSaleData">
        <parameter property="id"/>
        <parameter property="gasStationId"/>
        <parameter property="oilType"
                   typeHandler="com.ruoyi.gas.module.price.mapper.handler.OilTypeHandler"/>
        <parameter property="LNumber"/>
        <parameter property="KgNumber"/>
        <parameter property="price"/>
        <parameter property="date"
                   typeHandler="com.ruoyi.gas.module.price.mapper.handler.DateTimeHandler"/>
        <parameter property="batch"/>
    </parameterMap>

    <select id="selectHistorySaleData" resultMap="OilSaleData">
        select *
        from `gas_station_sale_data`
        where `gas_station_id` = #{gasStationId}
          and `effective` = true
        order by `id` DESC;
    </select>

    <select id="selectSaleData" parameterMap="OilSaleData" resultMap="OilSaleData">
        select *
        from `gas_station_sale_data`
        <where>
            <if test="id != null">and id=#{id}</if>
            <if test="gasStationId != null">and `gas_station_id` = #{gasStationId}</if>
            <if test="oilType != null">and `oil_type` = #{oilType}</if>
            <if test="LNumber != null">and l_number = #{LNumber}</if>
            <if test="KgNumber != null">and kg_number = #{KgNumber}</if>
            <if test="price != null">and price = #{price}</if>
            <if test="date != null">and date = #{date}</if>
            <if test="batch != null">and batch = #{batch}</if>
            and `efffective` = TRUE;
        </where>
    </select>

    <insert id="addSaleData" parameterMap="OilSaleData">
        insert into `gas_station_sale_data`(`gas_station_id`, `price`, `l_number`, `kg_number`, `oil_type`, `date`)
            value (#{gasStationId},#{price},#{LNumber},#{KgNumber},#{oilType},#{date});
    </insert>

    <update id="deleteSaleData">
        update `gas_station_sale_data`
        set `effective` = 0
        where `id` = #{id};
    </update>

    <select id="selectTotalPrice">
        select sum(`price`)
        from `gas_station_sale_data`
        where `gas_station_id` = #{gasStationId}
          and `effect` = true
          and `oil_type` = #{oilType}
          and `date` &gt;= #{startTime}
          and `date` $lt #{endTime};
    </select>

    <select id="selectTotalSalesVolume">
        select sum(`l_number`)
        from `gas_station_sale_data`
        where `gas_station_id` = #{gasStationId}
          and `effect` = true
          and `oil_type` = #{oilType}
          and `date` &gt;= #{startTime}
          and `date` $lt #{endTime};
    </select>

    <update id="rollBackLastBatch">
        update `gas_station_sale_data`
        set `effective` = FALSE
        where `batch` = (select `a`.`max`
                         from (select max(`batch`) as `max`
                               from `gas_station_sale_data`
                               where `effective` = TRUE) as `a`
        );
    </update>

    <select id="selectLastBatch" parameterType="java.lang.Integer">
        select max(`batch`)
        from `gas_station_sale_data`;
    </select>

    <select id="selectLastEffectiveBatch" parameterType="java.lang.Integer">
        select max(`batch`)
        from `gas_station_sale_data`
        where `effective` = TRUE;
    </select>
</mapper>