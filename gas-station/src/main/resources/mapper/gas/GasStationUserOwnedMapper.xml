<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.gas.module.geo.mapper.GasStationUserOwnedMapper">
    
    <resultMap type="GasStationUserOwned" id="GasStationUserOwnedResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="stationId"    column="station_id"    />
        <result property="stationName"    column="station_name"    />
        <result property="status"    column="status"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectGasStationUserOwnedVo">
        select id, user_id, station_id, station_name, status, update_time from gas_station_user_owned
    </sql>

    <select id="selectGasStationUserOwnedList" parameterType="GasStationUserOwned" resultMap="GasStationUserOwnedResult">
        <include refid="selectGasStationUserOwnedVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="stationId != null  and stationId != ''"> and station_id = #{stationId}</if>
            <if test="stationName != null  and stationName != ''"> and station_name = #{stationName}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectGasStationUserOwnedById" parameterType="Long" resultMap="GasStationUserOwnedResult">
        <include refid="selectGasStationUserOwnedVo"/>
        where id = #{id}
    </select>

    <insert id="insertGasStationUserOwned" parameterType="GasStationUserOwned" useGeneratedKeys="true" keyProperty="id">
        insert into gas_station_user_owned
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="stationId != null and stationId != ''">station_id,</if>
            <if test="stationName != null and stationName != ''">station_name,</if>
            <if test="status != null">status,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="stationId != null and stationId != ''">#{stationId},</if>
            <if test="stationName != null and stationName != ''">#{stationName},</if>
            <if test="status != null">#{status},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateGasStation" parameterType="GasStationUserOwned">
        update gas_station_user_owned
        <trim prefix="SET" suffixOverrides=",">
            <if test="stationName != null and stationName != ''">station_name = #{stationName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id} or (user_id = #{userId} and station_id = #{stationId})
    </update>

    <delete id="deleteGasStationUserOwnedById" parameterType="Long">
        delete from gas_station_user_owned where id = #{id}
    </delete>

    <delete id="deleteGasStationUserOwnedByIds" parameterType="String">
        delete from gas_station_user_owned where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>