<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.gas.module.price.mapper.OilPriceMapper">

    <resultMap id="OilPrice" type="com.ruoyi.gas.module.price.domain.framwork.OilPrice">
        <result property="gasStationId" column="gas_station_id"/>
        <result property="outGasStationId" column="out_gas_station_id"/>
        <result property="periodId" column="period_id"/>
        <result property="oilType" column="oil_type"
                typeHandler="com.ruoyi.gas.module.price.mapper.handler.OilTypeHandler"/>
        <result property="price" column="price"/>
    </resultMap>

    <parameterMap id="OilPrice" type="com.ruoyi.gas.module.price.domain.framwork.OilPrice">
        <parameter property="gasStationId"/>
        <parameter property="outGasStationId"/>
        <parameter property="periodId"/>
        <parameter property="oilType"
                   typeHandler="com.ruoyi.gas.module.price.mapper.handler.OilTypeHandler"/>
        <parameter property="price"/>
    </parameterMap>

    <insert id="addEmptyPrice">
        insert into `gas_station_oil_price`(`gas_station_id`, `out_gas_station_id`, `period_id`)
            value (#{gasStationId},#{outGasStationId} , #{periodId});
    </insert>

    <select id="selectPrice" resultMap="OilPrice">
        select `gas_station_id`,
               `out_gas_station_id`,
               `period_id`,
               `price_#{oilType}` as `price`,
               #{oilType}         as `oil_type`
        from `gas_station_oil_price`
        where `gas_station_id` = #{gasStationId}
          and `out_gas_station_id` = #{outGasStationId}
          and `period_id` = #{periodId}
    </select>

    <select id="selectHistoryPrice" resultMap="OilPrice">
        select `gas_station_id`,
               `out_gas_station_id`,
               `period_id`,
               `price_#{oilType}` as `price`,
               #{oilType}         as `oil_type`
        from `gas_station_oil_price`
        where `gas_station_id` = #{gasStationId}
        order by `period_id` DESC;
    </select>

    <update id="updatePrice" parameterType="OilPrice">
        update `gas_station_oil_price`
        set `price_${oilType}` = #{price}
        where `gas_station_id` = #{gasStationId}
          and `period_id` = #{periodId}
          and `out_gas_station_id` = #{outGasStationId}
    </update>

    <delete id="deletePrice">
        delete
        from `gas_station_oil_price`
        where `gas_station_id` = #{gasStationId}
          and `out_gas_station_id` = #{outGasStationId}
          and `period_id` = #{periodId};
    </delete>
</mapper>